{
  "name": "take-a-break-meow",
  "version": "1.0.0",
  "description": "Friendly usage timer — when time is up, a cat takes over until your break ends.",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "app:mac": "electron-builder --dir --mac && open \"$(find dist -maxdepth 3 -name '*.app' | head -n 1)\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win:msix": "electron-builder --win msix"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.shrikant-badwaik.takeabreakmeow.app",
    "productName": "Take a break, Meow",
    "files": ["main.js", "preload.js", "*.html", "assets/**", "build/**"],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": [
        {
          "target": "msix",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "shrikant-badwaik",
      "verifyUpdateCodeSignature": false
    },
    "appx": {
      "identityName": "shrikant-badwaik.TakeabreakMeow",
      "publisher": "CN=CE1F313D-42F7-404E-B32F-62FB404E7CBB",
      "publisherDisplayName": "shrikant-badwaik",
      "applicationId": "shrikant-badwaik.TakeabreakMeow",
      "backgroundColor": "#faf6ef",
      "showNameOnTiles": true,
      "languages": ["en-US"]
    }
  }
}
